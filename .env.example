CHAT_SERVICE_ADDR=:9090
CHAT_REPOSITORY=postgres
CHAT_DB_DSN=postgres://chat_user:chat_pass@localhost:55432/chat_service?sslmode=disable

# Optional for migration integration test
CHAT_SERVICE_TEST_PG_DSN=postgres://chat_user:chat_pass@localhost:55432/chat_service?sslmode=disable

# Optional: enable signed GCS upload URLs for image/file attachments.
# The server uses Application Default Credentials (ADC), for example:
#   gcloud auth application-default login
# If plain user ADC cannot auto-detect a signing identity, set:
#   GCP_SIGNING_SERVICE_ACCOUNT_EMAIL=signer@your-project.iam.gserviceaccount.com
# or use GOOGLE_APPLICATION_CREDENTIALS if you prefer a service account key.
# The configured bucket is also used as the trusted attachment bucket for
# IMAGE/FILE message URL validation.
# Optional: signed read URL expiry in minutes for attachment responses.
# Default is 30.
GCP_STORAGE_BUCKET=your-gcs-bucket-name
GCP_SIGNING_SERVICE_ACCOUNT_EMAIL=signer@your-project.iam.gserviceaccount.com
GCS_READ_URL_EXPIRES_MINUTES=30

# Note:
# - the canonical bucket env var in this repo is GCP_STORAGE_BUCKET
# - GCS_UPLOAD_URL_EXPIRES_MINUTES is not implemented yet
